    <meta name="description" content="Carrusel de dinosaurios sin JavaScript">
    <title>Carrusel de Dinosaurios</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #c8e6c9; /* verde suave */
            text-align: center;
        }

        .barra {
            width: 100%;
            display: flex;
        }

        .boton {
            flex: 1;
            padding: 20px;
            background-color: #81c784;
            text-decoration: none;
            color: black;
            font-weight: bold;
            border: 1px solid #4caf50;
        }

        .boton:hover {
            background-color: #66bb6a;
        }

        .carrusel {
            position: relative;
            width: 600px;
            height: 400px;
            margin: 40px auto;
        }

        .slide {
            position: absolute;
            width: 100%;
            height: 100%;
            opacity: 0;
            z-index: 0;
        }

        .slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: 4px solid #4caf50;
            border-radius: 10px;
        }

        /* Primera visible por defecto */
        #slide1 {
            opacity: 1;
            z-index: 1;
        }

        /* Cuando se selecciona */
        .slide:target {
            opacity: 1;
            z-index: 2;
        }
    </style>
</head>

<body>

<div class="carrusel">

